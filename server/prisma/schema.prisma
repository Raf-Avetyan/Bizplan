generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  name                 String
  email                String         @unique
  password             String
  businessPlans        BusinessPlan[]
  activeBusinessPlanId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model BusinessPlan {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName   String
  place          String
  uniqueTags     String[]
  idea           String
  additionalData Json?    @default("{}")
  financialData  Json?    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("companies")
}
